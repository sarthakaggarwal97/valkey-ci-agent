# Local developer environment template.
# Copy to `.env.local`, fill in your values, and source it manually.
# Do not commit `.env.local`.

# GitHub token for API-backed local runs.
GITHUB_TOKEN=

# Narrow credential and HTTPS origin for the internal model gateway.
AI_GATEWAY_UPSTREAM_URL=https://gateway.example.invalid
AI_GATEWAY_TOKEN=

# Optional local operational overrides.
VALKEY_CI_AGENT_KILL_SWITCH=false
VALKEY_CI_AGENT_DISABLED_REPOSITORIES=
VALKEY_CI_AGENT_DISABLE_BACKPORT=false
VALKEY_CI_AGENT_DISABLE_CI_FIX=false
VALKEY_CI_AGENT_DISABLE_FUZZER=false
VALKEY_CI_AGENT_DISABLE_TEST_FAILURE_DETECTOR=false
VALKEY_CI_AGENT_DISABLE_METADATA_RECONCILER=false
