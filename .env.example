# Local developer environment template.
# Copy to `.env.local`, fill in your values, and source it manually.
# Do not commit `.env.local`.

# GitHub token for API-backed local runs.
GITHUB_TOKEN=

# AWS authentication for local boto3 usage.
# Prefer `AWS_PROFILE` for local development. `AWS_ROLE_ARN` is included as a reminder
# for the GitHub Actions OIDC role you configure in the repository secrets.
AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/valkey-ci-agent

# Optional commit identity for automated PRs and backports.
# Set these when the target repository requires DCO-signed commits.
CI_BOT_COMMIT_NAME=
CI_BOT_COMMIT_EMAIL=
CI_BOT_REQUIRE_DCO_SIGNOFF=false

# Optional publish guard override for local dry-run-free tests.
# Required before writing to protected repos from local runs.
VALKEY_CI_AGENT_ALLOW_VALKEY_IO_PUBLISH=
